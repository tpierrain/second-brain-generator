{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Agent",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git rebase:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(mkdir:*)",
      "Bash(grep:*)",
      "Bash(node --import tsx --test:*)",
      "Bash(npm test:*)",
      "mcp__vault-rag__search_vault",
      "mcp__vault-rag__get_document",
      "mcp__vault-rag__list_documents",
      "mcp__vault-rag__vault_stats"
    ],
    "deny": [],
    "additionalDirectories": [
      "{{TMP_DIR}}"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{PROJECT_ROOT}}/scripts/auto-commit.mjs\"",
            "timeout": 30000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"{{PROJECT_ROOT}}/scripts/session-status.mjs\"",
            "timeout": 20000
          }
        ]
      }
    ]
  }
}
